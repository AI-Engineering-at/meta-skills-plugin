+  # ============================================
+  # JOB 6: Statusline Formatter Boundary Tests
+  # Blocks merge if boundary bugs return (e.g. $1000k glitch).
+  # ============================================
+  format-tests:
+    name: Format Boundary Tests
+    runs-on: ubuntu-latest
+    needs: syntax
+    steps:
+      - uses: actions/checkout@v4
